<window width="800" height="600" color="#000000">
  <panel x="10" y="10" width="780" height="580" color="#202020">
    <text x="20" y="20" label="Image Test Page - Alternative" color="#FFFFFF"/>
    <image x="300" y="60" width="200" height="150" src="test_image.jpg"/>
    <button x="300" y="250" width="100" height="30" label="Test Button" onClick="test_button()"/>
    <textfield x="300" y="300" width="200" height="30" value="Test text field"/>
  </panel>
</window>