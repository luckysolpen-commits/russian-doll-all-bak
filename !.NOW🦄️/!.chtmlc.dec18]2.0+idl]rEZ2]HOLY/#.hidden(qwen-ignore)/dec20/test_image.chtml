<window width="800" height="600" color="#000000">
  <panel x="10" y="10" width="780" height="580" color="#202020">
    <text x="20" y="20" label="Image Test Page" color="#FFFFFF"/>
    <img x="50" y="60" width="200" height="150" src="nonexistent_image.png"/>
    <button x="50" y="250" width="100" height="30" label="Button 1" onClick="button1_clicked()"/>
    <button x="160" y="250" width="100" height="30" label="Button 2" onClick="button2_clicked()"/>
    <slider x="50" y="300" width="200" height="20" min="0" max="100" value="50" id="slider1"/>
  </panel>
</window>