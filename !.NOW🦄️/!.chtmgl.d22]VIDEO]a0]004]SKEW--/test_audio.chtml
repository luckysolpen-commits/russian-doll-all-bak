<window width="600" height="400" color="#222222">
    <text x="20" y="30" value="Audio Player Test" color="#FFFFFF" />
    <text x="20" y="60" value="Click the PLAY/STOP buttons on the audio element" color="#FFFFFF" />
    
    <!-- Audio element with gowon.mp3 file -->
    <audio x="50" y="100" width="500" height="80" src="gowon.mp3" />
    
    <text x="20" y="200" value="The audio element above should show PLAY and STOP buttons" color="#FFFFFF" />
    <text x="20" y="230" value="Click PLAY to start audio, STOP to stop audio" color="#FFFFFF" />
</window>