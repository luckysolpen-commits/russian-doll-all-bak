<window width="800" height="600" color="#000000">
  <header x="10" y="10" width="780" height="50" label="CHTML Video Test" color="#336699" alpha="1.0" />
  
  <!-- Video element example -->
  <video src="soli.mp4" x="50" y="100" width="400" height="300" autoplay="false" loop="true" />
  
  <!-- Video controls -->
  <button x="50" y="420" width="100" height="30" label="Play Video" onClick="play_video_clicked" />
  <button x="160" y="420" width="100" height="30" label="Pause Video" onClick="pause_video_clicked" />
  <button x="270" y="420" width="100" height="30" label="Stop Video" onClick="stop_video_clicked" />
  
  <!-- Text to show status -->
  <text x="50" y="470" width="300" height="30" label="Video Status: Not Playing" id="video_status" color="#FFFFFF" />
  
  <!-- Simple controls -->
  <button x="500" y="500" width="100" height="30" label="Close" onClick="exit_app" />
</window>