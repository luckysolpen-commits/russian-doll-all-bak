<!DOCTYPE html>
<html>
<head>
    <title>Texture Demo</title>
</head>
<body>
    <!-- Main window -->
    <window x="100" y="100" width="800" height="600" label="Texture Demo">
        <color>#000000</color>  <!-- Black background -->
    </window>

    <!-- Canvas for 2D rendering -->
    <canvas x="50" y="50" width="700" height="300" view_mode="2d" label="2D Canvas">
        <color>#222222</color>  <!-- Dark gray background for canvas -->
        <alpha>0.9</alpha>
    </canvas>

    <!-- Canvas for 3D rendering -->
    <canvas x="50" y="370" width="700" height="200" view_mode="3d" label="3D Canvas">
        <color>#333333</color>  <!-- Slightly lighter gray for 3D canvas -->
        <alpha>0.9</alpha>
        <fov>60</fov>  <!-- Field of view for 3D perspective -->
    </canvas>

    <!-- Instructions -->
    <text x="600" y="20" label="Use arrow keys to move blue square" width="200" height="30" />
    <text x="600" y="540" label="Press '3' for 3D view" width="200" height="30" />

    <!-- Module that renders textured shapes -->
    <module protocol="pipe">module/+x/simple_texture_demo.+x</module>
</body>
</html>