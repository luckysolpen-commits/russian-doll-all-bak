<window x="100" y="100" width="800" height="600" color="#000000" label="Shared Memory Player Movement Demo"></window>

<!-- Header bar with player position text -->
<panel x="0" y="0" width="100%" height="40" color="#222222">
    <text x="10" y="15" value="Player Position: X: 0, Y: 0, Z: 0" id="position_display" color="#FFFFFF" />
</panel>

<!-- Main canvas showing 3D player -->
<canvas x="50" y="60" width="600" height="400" color="#111111" alpha="0.8" viewMode="3d" id="main_view">
    <!-- 3D Player will be rendered here -->
</canvas>

<!-- Mini map in separate canvas -->
<canvas x="670" y="60" width="120" height="120" color="#111111" alpha="0.8" viewMode="2d" id="mini_map_view">
    <!-- 2D mini map of player position -->
</canvas>

<!-- Player controls information -->
<text x="670" y="190" value="Controls:" color="#FFFFFF" />
<text x="670" y="210" value="Arrow Keys" color="#FFFF00" />
<text x="670" y="230" value="to move" color="#FFFFFF" />

<!-- Status display -->
<text x="670" y="270" value="Status:" color="#FFFFFF" />
<text x="670" y="290" value="Starting shared module..." id="status_display" color="#00FF00" />

<!-- SHARED MEMORY Module that handles player movement -->
<module protocol="shared">module/+x/shared_player_movement.+x</module>

<!-- Buttons for direct control -->
<button x="670" y="400" width="120" height="30" label="Move Up" id="btn_up" onClick="player_move_up" color="#4444FF" />
<button x="670" y="440" width="120" height="30" label="Move Down" id="btn_down" onClick="player_move_down" color="#4444FF" />
<button x="670" y="480" width="120" height="30" label="Reset Pos" id="btn_reset" onClick="player_reset" color="#FF4444" />