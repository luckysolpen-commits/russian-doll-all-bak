<window x="110" y="110" width="1800" height="1600" color="#000000" label="Z-Level Test Window">
</window>

<panel x="50" y="50" width="200" height="200" color="#FF0000" z_level="3">
  <text x="10" y="10" label="Panel 1 (z=3)" />
</panel>

<panel x="100" y="100" width="200" height="200" color="#00FF00" z_level="2">
  <text x="10" y="10" label="Panel 2 (z=2)" />
</panel>

<panel x="150" y="150" width="200" height="200" color="#0000FF" z_level="4">
  <text x="10" y="10" label="Panel 3 (z=4)" />
</panel>
