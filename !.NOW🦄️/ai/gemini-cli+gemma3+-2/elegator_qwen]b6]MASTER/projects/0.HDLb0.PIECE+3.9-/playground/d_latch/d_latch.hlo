# D-Latch (Level-Triggered Flip-Flop) from NAND gates
#
# Inputs:
#   D: switch_0 (address 5)
#   CLK: clock (address 7)
# Output:
#   Q: ram[16] (also written to tape)
#
# Logic: Q_next = (D AND CLK) OR (Q AND NOT_CLK)
#
# ram[16] = Q (output)
# ram[17] = NOT_CLK
# ram[18] = D_AND_CLK
# ram[19] = Q_AND_NOT_CLK
# ram[20-23] = temporary values

# 1. NOT_CLK = NAND(CLK, CLK) -> ram[17]
0000000000000001 0000000000010001 0000000000000111 0000000000000111

# 2. D_AND_CLK = NAND(NAND(D, CLK), NAND(D, CLK)) -> ram[18]
# 2a. tmp1 = NAND(D, CLK) -> ram[20]
0000000000000001 0000000000010100 0000000000000101 0000000000000111
# 2b. D_AND_CLK = NAND(tmp1, tmp1) -> ram[18]
0000000000000001 0000000000010010 0000000000010100 0000000000010100

# 3. Q_AND_NOT_CLK = NAND(NAND(Q, NOT_CLK), NAND(Q, NOT_CLK)) -> ram[19]
# 3a. tmp2 = NAND(Q, NOT_CLK) -> ram[21]
0000000000000001 0000000000010101 0000000000010000 0000000000010001
# 3b. Q_AND_NOT_CLK = NAND(tmp2, tmp2) -> ram[19]
0000000000000001 0000000000010011 0000000000010101 0000000000010101

# 4. Q_next = OR(D_AND_CLK, Q_AND_NOT_CLK) -> ram[16]
#    OR(A,B) = NAND(NAND(A,A), NAND(B,B))
# 4a. tmp3 = NAND(D_AND_CLK, D_AND_CLK) -> ram[22]
0000000000000001 0000000000010110 0000000000010010 0000000000010010
# 4b. tmp4 = NAND(Q_AND_NOT_CLK, Q_AND_NOT_CLK) -> ram[23]
0000000000000001 0000000000010111 0000000000010011 0000000000010011
# 4c. Q_next = NAND(tmp3, tmp4) -> ram[16]
0000000000000001 0000000000010000 0000000000010110 0000000000010111

# 5. Output final result from ram[16] to tape
0000000000000000 0000000000000000 0000000000010000 0000000000000011
